@model CreateRegisterDto
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8">
	<title>Giriş Yap</title>
	<!-- Mobile Specific Metas -->
	<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
	<!-- Font-->
	<link rel="stylesheet" type="text/css" href="~/colorlib-regform-30/css/opensans-font.css">
	<link rel="stylesheet" type="text/css" href="~/colorlib-regform-30/fonts/line-awesome/css/line-awesome.min.css">
	<!-- Jquery -->
	<link rel="stylesheet" href="https://jqueryvalidation.org/files/demo/site-demos.css">
	
	<link rel="stylesheet" href="~/colorlib-regform-30/css/style.css" />
</head>
<body class="form-v4" style="background-color:#ff7f00  !important; ">
	<div class="page-content" style="background-color:#ff7f00  !important; ">
		<div class="form-v4-content">
			<div class="form-left">
				<h3>Turuncu E Ticaret Sitesi</h3>
				<p class="text-1">Sevdikleriniz için en güzel hediyeleri, ihtiyaçlarınızı karşılayan en kaliteli ürünleri hızlı, güvenilir ve uygun fiyatlarla sunuyoruz! 💼</p>
				<p class="text-2"><span>🛒 Özel Fırsatlar:</span>  Sadece size özel indirimler ve kampanyalarla alışverişinizi daha keyifli hale getiriyoruz.</p>
				<button type="submit" style="padding:10px; background-color:white; color:#2259b3; font-size:20px; border:none; border-radius:8px; cursor:pointer;">Giriş Yap</button>
			</div>
			<form class="form-detail"  method="post" >
				<h2>Kayıt ol Formu</h2>
				<div class="form-group">
					<div class="form-row form-row-1">
						<label for="first_name">İsim</label>
						<input type="text" asp-for="Name" id="first_name" class="input-text">
					</div>
					<div class="form-row form-row-1">
						<label for="last_name">Soyisim</label>
						<input type="text"  asp-for="Surname" id="last_name" class="input-text">
					</div>
				</div>
				<div class="form-row">
					<label for="your_email">Email</label>
					<input type="text" asp-for="Email" id="your_email" class="input-text" required pattern="[^@@]+@@[^@@]+.[a-zA-Z]{2,6}">
				</div><div class="form-row">
					<label for="your_email">Kullanıcı Adınız</label>
					<input type="text" asp-for="UserName" id="your_username" class="input-text" required>
				</div>
				<div class="form-group">
					<div class="form-row form-row-1 ">
						<label for="password">Şifre</label>
						<input type="password" asp-for="Password" id="password" class="input-text" required>
					</div>
					<div class="form-row form-row-1">
						<label for="comfirm-password">Şifre Tekrar</label>
						<input type="password" asp-for="ComfirmPassword" id="comfirm_password" class="input-text" required>
					</div>
					
				</div>
				<div class="form-checkbox" style="display:flex; flex-direction:row">
					<label class="container"><p>Şartları Okudum <a href="#" class="text">Kabul Ediyorum</a></p>
					  	<input type="checkbox" name="checkbox">
					  	<span class="checkmark"></span>
					</label>
				</div>
				<br />
				<button type="submit" style="padding:10px; background-color:#2259b3; color:white; font-size:20px; border:none; border-radius:8px;cursor:pointer;">Kayıt ol</button>
			</form>
		</div>
	</div>
	<script src="https://code.jquery.com/jquery-1.11.1.min.js"></script>
	<script src="https://cdn.jsdelivr.net/jquery.validation/1.16.0/jquery.validate.min.js"></script>
	<script src="https://cdn.jsdelivr.net/jquery.validation/1.16.0/additional-methods.min.js"></script>
	<script>
		// just for the demos, avoids form submit
		jQuery.validator.setDefaults({
		  	debug: true,
		  	success:  function(label){
        		label.attr('id', 'valid');
   		 	},
		});
		$( "#myform" ).validate({
		  	rules: {
			    password: "required",
		    	comfirm_password: {
		      		equalTo: "#password"
		    	}
		  	},
		  	messages: {
		  		first_name: {
		  			required: "Please enter a firstname"
		  		},
		  		last_name: {
		  			required: "Please enter a lastname"
		  		},
		  		your_email: {
		  			required: "Please provide an email"
		  		},
		  		password: {
	  				required: "Please enter a password"
		  		},
		  		comfirm_password: {
		  			required: "Please enter a password",
		      		equalTo: "Wrong Password"
		    	}
		  	}
		});
	</script>
</body><!-- This templates was made by Colorlib (https://colorlib.com) -->
</html>