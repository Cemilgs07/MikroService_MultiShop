@model CreateContactDto
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/_UILayout/_UILayout.cshtml";
}

<!-- Breadcrumb Start -->
<div class="container-fluid">
    <div class="row px-xl-5">
        <div class="col-12">
            <nav class="breadcrumb bg-light mb-30">
                <a class="breadcrumb-item text-dark" href="#">Anasayfa</a>
                <span class="breadcrumb-item active">İletişim</span>
            </nav>
        </div>
    </div>
</div>
<!-- Breadcrumb End -->
<!-- Contact Start -->
<div class="container-fluid">
    <h2 class="section-title position-relative text-uppercase mx-xl-5 mb-4"><span class="bg-secondary pr-3">İletişim'e Geç</span></h2>
    <div class="row px-xl-5">
        <div class="col-lg-7 mb-5">
            <div class="contact-form bg-light p-30">
                <div id="success"></div>
                <form  method="post" novalidate="novalidate">
                    <div class="control-group">
                        <input type="text" asp-for="NameSurname" class="form-control" id="name" placeholder="İsminiz"
                               required="required" data-validation-required-message="İsminizi Giriniz" />
                        <p class="help-block text-danger"></p>
                    </div>
                    <div class="control-group">
                        <input type="email" asp-for="Email" class="form-control" id="email" placeholder=" Email Adresiniz"
                               required="required" data-validation-required-message="Mail Adresini Giriniz" />
                        <p class="help-block text-danger"></p>
                    </div>
                    <div class="control-group">
                        <input type="text" asp-for="Subject" class="form-control" id="subject" placeholder="Subject"
                               required="required" data-validation-required-message="Konu Giriniz" />
                        <p class="help-block text-danger"></p>
                    </div>
                    <div class="control-group">
                        <textarea class="form-control" asp-for="Message" rows="8" id="message" placeholder="Message"
                                  required="required"
                                  data-validation-required-message="Mesajınızı Giriniz."></textarea>
                        <p class="help-block text-danger"></p>
                    </div>
                    <div>
                        <button class="btn btn-info py-2 px-4" type="submit" id="sendMessageButton">
                           Mesajı Gönder
                        </button>
                    </div>
                </form>
            </div>
        </div>
        @await Component.InvokeAsync("_ContactDetailPartialComponentPartial");
    </div>
</div>
<!-- Contact End -->
