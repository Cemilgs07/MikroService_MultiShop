@{
    ViewData["Title"] = "ProductDetail";
    Layout = "~/Views/_UILayout/_UILayout.cshtml";
}

<!-- Breadcrumb Start -->
<div class="container-fluid">
    <div class="row px-xl-5">
        <div class="col-12">
            <nav class="breadcrumb bg-light mb-30">
                <a class="breadcrumb-item text-dark" href="#">Home</a>
                <a class="breadcrumb-item text-dark" href="#">Ürün Listesi</a>
                <span class="breadcrumb-item active">Shop Detaylari</span>
            </nav>
        </div>
    </div>
</div>
<!-- Shop Detail Start -->
<div class="container-fluid pb-5">
    <div class="row px-xl-5">
        @await Component.InvokeAsync("_ProductDetailImageSliderComponentPartial",new {Id=ViewBag.x})
        @await Component.InvokeAsync("_ProductDetailFeaturesInfoComponentPartial",new {Id=ViewBag.x})
    </div>
    <div class="row px-xl-5">
        <div class="col">
            <div class="bg-light p-30">
                <div class="nav nav-tabs mb-4">
                    <a class="nav-item nav-link text-dark active" data-toggle="tab" href="#tab-pane-1">Açıklama</a>
                    <a class="nav-item nav-link text-dark" data-toggle="tab" href="#tab-pane-2">Bilgilendirme</a>
                    <a class="nav-item nav-link text-dark" data-toggle="tab" href="#tab-pane-3">Yorumlar</a>
                </div>
                <div class="tab-content">
                    @await Component.InvokeAsync("_ProductDetailDescriptionComponentPartial",new {Id=ViewBag.x})
                    @await Component.InvokeAsync("_ProductDetailInformationComponentPartial", new { Id = ViewBag.x })
                    @await Component.InvokeAsync("_ProductDetailReviewComponentPartial",new { Id = ViewBag.x })
                </div>
            </div>
        </div>
    </div>
</div>