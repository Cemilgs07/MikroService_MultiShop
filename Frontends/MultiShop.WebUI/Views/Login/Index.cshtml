@model LoginDto
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Giriş Yap</title>
    <!-- Mobile Specific Metas -->
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
    <!-- Font-->
    <link rel="stylesheet" type="text/css" href="~/colorlib-regform-30/css/opensans-font.css">
    <link rel="stylesheet" type="text/css" href="~/colorlib-regform-30/fonts/line-awesome/css/line-awesome.min.css">
    <!-- Jquery -->
    <link rel="stylesheet" href="https://jqueryvalidation.org/files/demo/site-demos.css">

    <link rel="stylesheet" href="~/colorlib-regform-30/css/style.css" />
</head>
<body class="form-v4" style="background-color:#ff7f00  !important; ">
    <div class="page-content" style="background-color:#ff7f00  !important; height:100%;">
        <div class="form-v4-content" style="background-color:white !important;">
            <div class="form-left">
                <h3>Turuncu E Ticaret Sitesi</h3>
                <p class="text-1">Sevdikleriniz için en güzel hediyeleri, ihtiyaçlarınızı karşılayan en kaliteli ürünleri hızlı, güvenilir ve uygun fiyatlarla sunuyoruz! 💼</p>
                <p class="text-2"><span>🛒 Özel Fırsatlar:</span>  Sadece size özel indirimler ve kampanyalarla alışverişinizi daha keyifli hale getiriyoruz.</p>
                <a href="/Register/Index" style="padding:10px; background-color:white; color:#2259b3; font-size:20px; border:none; text-decoration:none; border-radius:8px; cursor:pointer;">Kayıt Ol</a>
            </div>
            <form class="form-detail" method="post" >
                <h2>Turuncu E Ticaret Sitesine Giriş Yap</h2>

                <label for="first_name">Kullanıcı Adı</label>
                <input type="text" asp-for="UserName" id="first_name" class="input-text">

                <label for="last_name">Şifre</label>
                <input type="text" asp-for="Password" id="last_name" class="input-text">

                <br />
                <button class="form-control" type="submit" style="padding:10px; width: 100%; background-color:#2259b3; color:white; font-size:20px; border:none; border-radius:8px;cursor:pointer;">
                    Giriş Yap
                </button>
               
            </form>
            
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-1.11.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/jquery.validation/1.16.0/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/jquery.validation/1.16.0/additional-methods.min.js"></script>
    <script>
        // just for the demos, avoids form submit
        jQuery.validator.setDefaults({
            debug: true,
            success: function (label) {
                label.attr('id', 'valid');
            },
        });
        $("#myform").validate({
            rules: {
                password: "required",
                comfirm_password: {
                    equalTo: "#password"
                }
            },
            messages: {
                first_name: {
                    required: "Please enter a firstname"
                },
                last_name: {
                    required: "Please enter a lastname"
                },
                your_email: {
                    required: "Please provide an email"
                },
                password: {
                    required: "Please enter a password"
                },
                comfirm_password: {
                    required: "Please enter a password",
                    equalTo: "Wrong Password"
                }
            }
        });
    </script>
</body><!-- This templates was made by Colorlib (https://colorlib.com) -->
</html>