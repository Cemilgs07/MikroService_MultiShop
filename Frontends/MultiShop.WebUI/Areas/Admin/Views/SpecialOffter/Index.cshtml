@model List<ResultSpecialOfterDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
    var count = 0;
}

<section class="content container-fluid">
    <div class="row">
        <div class="col-md-12">
            <div class="chart-box">
                <h4>İndirim Listesi</h4>
                <br />
                <div class="bs-example" data-example-id="bordered-table">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>İndirim Başlık</th>
                                <th>İndirim İkinci Başlık</th>
                                <th>Sil</th>
                                <th>Güncelle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                count++;
                                <tr>
                                    <th scope="row">@count</th>
                                    <td class="align-middle">@item.Title</td>
                                    <td class="align-middle">@item.subTitle</td>
                                    <td><a href="/Admin/SpecialOffter/DeleteSpecialOftter/@item.SpecialOffterId" class="btn btn-danger">Sil</a></td>
                                    <td><a href="/Admin/SpecialOffter/UpdateSpecialOftter/@item.SpecialOffterId" class="btn btn-primary w-100">Güncelle</a></td>
                                </tr>
                            }

                        </tbody>
                    </table>
                    <br />
                    <a href="/Admin/SpecialOffter/CreateSpecialOffter" class="btn btn-success nav-link">Yeni İndirim Ekle</a>
                </div>
            </div>
        </div>
    </div>
</section>


