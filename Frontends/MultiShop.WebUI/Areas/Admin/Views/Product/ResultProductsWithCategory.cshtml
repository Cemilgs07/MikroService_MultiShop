@model List<ResultProductsWithCategoryDto>
@{
    ViewData["Title"] = "ResultProductsWithCategory";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
    var count = 0;
}

<section class="content container-fluid">
    <div class="row">
        <div class="col-md-12">
            <div class="chart-box">
                <h4>Ürün Detay Listesi</h4>
                <br />
                <div class="bs-example" data-example-id="bordered-table">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Kategori Adı</th>
                                <th>Ürün Adı</th>
                                <th>Ürün Fiyatı</th>
                                <th>Sil</th>
                                <th>Güncelle</th>
                                <th>Ürün Görselleri</th>
                                <th>Ürün Açıklaması</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                count++;
                                <tr>
                                    <th scope="row">@count</th>
                                    <td class="align-middle">@item.CategoryName</td>
                                    <td class="align-middle">@item.ProductName</td>
                                    <td class="align-middle">@item.ProductPrice</td>
                                    <td><a href="/Admin/Product/DeleteProduct/@item.ProductId" class="btn btn-danger">Sil</a></td>
                                    <td><a href="/Admin/Product/UpdateProduct/@item.ProductId" class="btn btn-primary w-100">Güncelle</a></td>
                                    <td><a href="/Admin/ProductImage/ImageDetails/@item.ProductId" class="btn btn-warning w-100">Ürün Görselleri</a></td>
                                    <td><a href="/Admin/ProductDetail/UpdateProductDetail/@item.ProductId" class="btn btn-info w-100">Ürün Açıklaması</a></td>
                                </tr>
                            }

                        </tbody>
                    </table>
                   
                </div>
            </div>
        </div>
    </div>
</section>


